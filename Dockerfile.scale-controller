FROM golang:1.25-alpine AS builder
WORKDIR /build
RUN apk add --no-cache git
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -trimpath -ldflags="-s -w" \
    -o /scale-controller \
    ./cmd/scale-controller

FROM alpine:3.21
RUN apk add --no-cache ca-certificates
COPY --from=builder /scale-controller /usr/local/bin/scale-controller
ENTRYPOINT ["scale-controller"]
