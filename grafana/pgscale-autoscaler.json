{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus scraping scale-controller (:9091) and CNPG pods",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "pgscale autoscaler - reactive vs predictive scaling decisions and observed DB metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["postgresql", "cnpg", "autoscaler", "pgscale"],
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "pgscale - Autoscaler",
  "uid": "pgscale-autoscaler",
  "version": 1,
  "weekStart": "",
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "default", "value": "default" },
        "hide": 0,
        "label": "Namespace",
        "name": "namespace",
        "options": [{ "selected": true, "text": "default", "value": "default" }],
        "query": "default",
        "skipUrlSync": false,
        "type": "textbox"
      },
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Scaling Decisions",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Main comparison panel. current = running replicas; reactive = signal from current load; predictive = EWMA forecast; final = max(reactive, predictive) clamped to [min, max]. In hybrid mode, predictive should lead current by 1–2 steps during ramp-up.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "instances",
            "drawStyle": "line",
            "fillOpacity": 6,
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "pointSize": 6,
            "showPoints": "always",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "min": 0,
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "current" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#60a5fa", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 3 },
              { "id": "custom.fillOpacity", "value": 15 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "reactive" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#fbbf24", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "predictive" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#a78bfa", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "final (applied)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#fb7185", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [3, 3], "fill": "dash" } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "max", "min"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "scaling_instances_current",
          "legendFormat": "current",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "scaling_instances_target_reactive",
          "legendFormat": "reactive",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "scaling_instances_target_predictive",
          "legendFormat": "predictive",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "scaling_instances_target_final",
          "legendFormat": "final (applied)",
          "refId": "D"
        }
      ],
      "title": "Instance Targets - Reactive vs Predictive vs Current",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 3,
      "title": "Controller - Observed Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Active DB connections observed by the controller each poll. raw = instantaneous Prometheus query result; moving avg = arithmetic mean over the full rolling history buffer (up to 24h).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "connections",
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "short",
          "min": 0,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "backends raw" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#34d399", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "backends avg" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#34d399", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [6, 3], "fill": "dash" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "id": 4,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "scaling_observer_metric_value{metric_name=\"backends\"}",
          "legendFormat": "backends raw",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "scaling_observer_metric_avg{metric_name=\"backends\"}",
          "legendFormat": "backends avg",
          "refId": "B"
        }
      ],
      "title": "Backends (connections)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Transactions per second observed by the controller. raw can transiently be 0 when rate() window doesn't align with Prometheus scrape; stale-value guard in the observer substitutes the last good value.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "TPS",
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "short",
          "min": 0,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "tps raw" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#60a5fa", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "tps avg" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#60a5fa", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [6, 3], "fill": "dash" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "id": 5,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "scaling_observer_metric_value{metric_name=\"tps\"}",
          "legendFormat": "tps raw",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "scaling_observer_metric_avg{metric_name=\"tps\"}",
          "legendFormat": "tps avg",
          "refId": "B"
        }
      ],
      "title": "TPS",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "CPU cores (sum across all pg-cluster pods) observed by the controller. Weight 0.5 - acts as secondary signal.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "cores",
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "short",
          "min": 0,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cpu_cores raw" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#fb923c", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "cpu_cores avg" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#fb923c", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [6, 3], "fill": "dash" } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "id": 6,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "scaling_observer_metric_value{metric_name=\"cpu_cores\"}",
          "legendFormat": "cpu_cores raw",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "scaling_observer_metric_avg{metric_name=\"cpu_cores\"}",
          "legendFormat": "cpu_cores avg",
          "refId": "B"
        }
      ],
      "title": "CPU Cores",
      "type": "timeseries"
    },
  ]
}
